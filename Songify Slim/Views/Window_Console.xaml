<mah:MetroWindow
    x:Class="Songify_Slim.Views.WindowConsole"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:Songify_Slim.Views"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:oxy="http://oxyplot.org/wpf"
    xmlns:properties="clr-namespace:Songify_Slim.Properties"
    xmlns:wpf="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
    Title="{DynamicResource menu_view_console}"
    Width="285"
    Height="285"
    MinHeight="285"
    MaxHeight="285"
    Closing="MetroWindow_Closing"
    IsWindowDraggable="False"
    Loaded="MetroWindow_Loaded"
    LostFocus="MetroWindow_LostFocus"
    ResizeMode="CanResize"
    ShowActivated="False"
    ShowMaxRestoreButton="False"
    ShowMinButton="False"
    mc:Ignorable="d">
    <Window.Resources>
        <!--  Dark OxyPlot tracker tooltip  -->
        <ControlTemplate x:Key="DarkTrackerTemplate" TargetType="{x:Type ContentControl}">
            <Border
                Padding="6"
                Background="#2A2A2A"
                BorderBrush="#555"
                BorderThickness="1"
                CornerRadius="4">
                <TextBlock Foreground="#DDDDDD" Text="{Binding Text}" />
            </Border>
        </ControlTemplate>
    </Window.Resources>

    <mah:MetroWindow.LeftWindowCommands>
        <mah:WindowCommands>
            <Button
                x:Name="BtnAttachDetach"
                Click="BtnAttachDetach_OnClick"
                ToolTip="{DynamicResource window_console_detach_attach}">
                <iconPacks:PackIconBootstrapIcons
                    x:Name="IconDetach"
                    Width="22"
                    Height="22"
                    Kind="LayoutSidebar" />
            </Button>
            <Button
                x:Name="BtnClearConsole"
                Click="BtnClearConsole_OnClick"
                ToolTip="{DynamicResource window_console_clear}">
                <iconPacks:PackIconBootstrapIcons
                    Width="22"
                    Height="22"
                    Kind="JournalX" />
            </Button>
        </mah:WindowCommands>
    </mah:MetroWindow.LeftWindowCommands>
    <mah:MetroWindow.RightWindowCommands>
        <mah:WindowCommands>
            <Button
                x:Name="btnLog"
                Click="BtnLog_OnClick"
                Content="{DynamicResource window_console_log}" />
            <Button
                x:Name="btnMetrics"
                Click="BtnMetrics_OnClick"
                Content="{DynamicResource window_console_api_metrics}" />
        </mah:WindowCommands>
    </mah:MetroWindow.RightWindowCommands>
    <TabControl>
        <TabItem x:Name="TiLog">
            <Grid Background="#252525">
                <RichTextBox
                    x:Name="richTextBox"
                    HorizontalContentAlignment="Left"
                    VerticalContentAlignment="Top"
                    Background="#252525"
                    BorderThickness="0"
                    IsReadOnly="True"
                    TextChanged="richTextBox_TextChanged">
                    <!--<RichTextBox.Resources>
                        <Style TargetType="{x:Type Paragraph}">
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Padding" Value="0,0,15,0" />
                        </Style>
                    </RichTextBox.Resources>-->
                </RichTextBox>
            </Grid>
        </TabItem>
        <TabItem x:Name="TiMetrics">
            <TabControl>
                <TabItem Header="{DynamicResource window_console_subtab_live}">
                    <Grid Margin="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Button
                            x:Name="BtnToGraph"
                            Grid.Row="0"
                            HorizontalAlignment="Right"
                            Click="BtnToGraph_OnClick"
                            Content="{DynamicResource window_console_graph}" />
                        <TextBlock
                            Grid.Row="1"
                            Margin="4,2,4,2"
                            FontSize="11"
                            Opacity="0.85"
                            Text="{DynamicResource window_console_live_rpm_section}"
                            TextWrapping="Wrap" />
                        <DataGrid
                            Grid.Row="2"
                            Margin="0,4,0,0"
                            AutoGenerateColumns="False"
                            HeadersVisibility="Column"
                            HorizontalScrollBarVisibility="Auto"
                            IsReadOnly="True"
                            ItemsSource="{Binding Rows}"
                            VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="*"
                                    MinWidth="60"
                                    Binding="{Binding Key}"
                                    Header="{DynamicResource window_console_endpoint}" />
                                <DataGridTextColumn
                                    Width="72"
                                    Binding="{Binding RequestsPerMinute}"
                                    Header="{DynamicResource window_console_requests_per_min}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
                <TabItem Header="{DynamicResource window_console_subtab_daily}">
                    <Grid Margin="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel
                            Grid.Row="0"
                            Margin="0,0,0,4"
                            Orientation="Horizontal">
                            <TextBlock
                                VerticalAlignment="Center"
                                Margin="0,0,6,0"
                                Text="{DynamicResource window_console_daily_day}" />
                            <ComboBox
                                MinWidth="110"
                                VerticalAlignment="Center"
                                ItemsSource="{Binding DailyDayOptions}"
                                SelectedItem="{Binding SelectedDailyDayKey, Mode=TwoWay}" />
                        </StackPanel>
                        <TextBlock
                            Grid.Row="1"
                            Margin="0,0,0,4"
                            FontSize="11"
                            Opacity="0.85"
                            Text="{DynamicResource window_console_daily_success_section}"
                            TextWrapping="Wrap" />
                        <DataGrid
                            Grid.Row="2"
                            AutoGenerateColumns="False"
                            HeadersVisibility="Column"
                            HorizontalScrollBarVisibility="Auto"
                            IsReadOnly="True"
                            ItemsSource="{Binding DailySuccessRows}"
                            VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="*"
                                    MinWidth="60"
                                    Binding="{Binding Key}"
                                    Header="{DynamicResource window_console_endpoint}" />
                                <DataGridTextColumn
                                    Width="72"
                                    Binding="{Binding SuccessfulCalls}"
                                    Header="{DynamicResource window_console_successful_calls}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
                <TabItem Header="{DynamicResource window_console_subtab_429}">
                    <Grid Margin="4">
                        <DataGrid
                            AutoGenerateColumns="False"
                            HeadersVisibility="Column"
                            HorizontalScrollBarVisibility="Auto"
                            IsReadOnly="True"
                            ItemsSource="{Binding DailyRateLimitRows}"
                            VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="110"
                                    Binding="{Binding TimeLocal}"
                                    Header="{DynamicResource window_console_time}" />
                                <DataGridTextColumn
                                    Width="*"
                                    MinWidth="48"
                                    Binding="{Binding Key}"
                                    Header="{DynamicResource window_console_endpoint}" />
                                <DataGridTextColumn
                                    Width="56"
                                    Binding="{Binding RetryAfterSeconds}"
                                    Header="{DynamicResource window_console_retry_after}" />
                                <DataGridTextColumn
                                    Width="56"
                                    Binding="{Binding SuccessfulTotalAtEvent}"
                                    Header="{DynamicResource window_console_total_at_event}" />
                                <DataGridTextColumn
                                    Width="56"
                                    Binding="{Binding SuccessfulForKeyAtEvent}"
                                    Header="{DynamicResource window_console_key_at_event}" />
                                <DataGridTextColumn
                                    Width="48"
                                    Binding="{Binding RollingRpmAtEvent}"
                                    Header="{DynamicResource window_console_rolling_rpm}" />
                                <DataGridTextColumn
                                    Width="52"
                                    Binding="{Binding LikelyDailyQuota}"
                                    Header="{DynamicResource window_console_daily_quota_hint}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>
        </TabItem>
        <TabItem x:Name="TiGraph">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Button
                    x:Name="BtnToMetrics"
                    Grid.Row="0"
                    HorizontalAlignment="Right"
                    Click="BtnToMetrics_OnClick"
                    Content="{DynamicResource window_console_metrics}" />
                <local:ApiChart Grid.Row="1" Margin="10" />
                <!--<oxy:PlotView
                    Grid.Row="1"
                    Background="Transparent"
                    DefaultTrackerTemplate="{StaticResource DarkTrackerTemplate}"
                    IsHitTestVisible="True"
                    Model="{Binding PlotModel}" />-->
            </Grid>
        </TabItem>
    </TabControl>
</mah:MetroWindow>