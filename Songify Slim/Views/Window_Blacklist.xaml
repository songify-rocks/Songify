        <ListBox
            x:Name="ListView_Blacklist"
            Grid.Row="2"
            Grid.Column="0"
            Margin="6"
            BorderThickness="1"
            KeyDown="ListView_Blacklist_KeyDown">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem
                        d:Header="{DynamicResource window_blocklist_delete}"
                        Click="MenuItem_Click"
                        Header="{DynamicResource window_blocklist_delete}" />
                </ContextMenu>
            </ListBox.ContextMenu>
        </ListBox>
        <ListBox
            x:Name="ListView_UserBlacklist"
            Grid.Row="2"
            Grid.Column="1"
            Margin="6"
            BorderThickness="1"
            KeyDown="ListView_UserBlacklist_KeyDown">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem
                        d:Header="{DynamicResource window_blocklist_delete}"
                        Click="MenuItem_Click"
                        Header="{DynamicResource window_blocklist_delete}" />
                </ContextMenu>
            </ListBox.ContextMenu>
        </ListBox>
        <ListBox
            x:Name="ListView_SongBlacklist"
            Grid.Row="2"
            Grid.Column="2"
            Margin="6"
            BorderThickness="1"
            DisplayMemberPath="ReadableName"
            KeyDown="ListView_SongBlacklist_KeyDown"
            SelectedValuePath="ReadableName">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem
                        d:Header="{DynamicResource window_blocklist_delete}"
                        Click="MenuItem_Click"
                        Header="{DynamicResource window_blocklist_delete}" />
                </ContextMenu>
            </ListBox.ContextMenu>
        </ListBox>
        <Label
            Grid.Row="1"
            Grid.Column="0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            d:Content="{DynamicResource window_blocklist_blocked_artists}"
            Content="{DynamicResource window_blocklist_blocked_artists}" />
        <Label
            Grid.Row="1"
            Grid.Column="1"
            VerticalAlignment="Top"
            d:Content="{DynamicResource window_blocklist_blocked_users}"
            Content="{DynamicResource window_blocklist_blocked_users}" />
        <Label
            Grid.Row="1"
            Grid.Column="2"
            VerticalAlignment="Top"
            d:Content="{DynamicResource window_blocklist_blocked_songs}"
            Content="{DynamicResource window_blocklist_blocked_songs}" />
        <ContentControl
            x:Name="cc_Content"
