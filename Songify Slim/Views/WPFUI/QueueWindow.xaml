<ui:FluentWindow
    x:Class="Songify_Slim.Views.WPFUI.QueueWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:util="clr-namespace:Songify_Slim.Util"
    Title="{DynamicResource WinTitle_Queue}"
    Width="640"
    Height="480"
    MinWidth="400"
    MinHeight="300"
    ExtendsContentIntoTitleBar="True"
    Loaded="Window_Loaded"
    ResizeMode="CanResizeWithGrip"
    WindowStartupLocation="Manual"
    mc:Ignorable="d">
    <ui:FluentWindow.Resources>
        <ResourceDictionary>
            <util:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <SolidColorBrush x:Key="RowNowPlaying" Color="#4682B4" />
            <SolidColorBrush x:Key="RowSongRequest" Color="#2E8B57" />
            <SolidColorBrush x:Key="RowSkipping" Color="#CD5C5C" />
        </ResourceDictionary>
    </ui:FluentWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Toolbar  -->
        <Border
            Grid.Row="0"
            Padding="12,8"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Border
                        Margin="0,0,8,0"
                        Padding="8,4"
                        Background="{StaticResource RowNowPlaying}"
                        CornerRadius="4">
                        <TextBlock
                            VerticalAlignment="Center"
                            Foreground="White"
                            Text="{DynamicResource WinQueue_NowPlaying}" />
                    </Border>
                    <Border
                        Margin="0,0,8,0"
                        Padding="8,4"
                        Background="{StaticResource RowSongRequest}"
                        CornerRadius="4">
                        <TextBlock
                            VerticalAlignment="Center"
                            Foreground="White"
                            Text="{DynamicResource WinQueue_SongRequest}" />
                    </Border>
                    <Border
                        Padding="8,4"
                        Background="{StaticResource RowSkipping}"
                        CornerRadius="4">
                        <TextBlock
                            VerticalAlignment="Center"
                            Foreground="White"
                            Text="{DynamicResource WinQueue_Skipping}" />
                    </Border>
                </StackPanel>
                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <ui:Button
                        x:Name="BtnClearQueue"
                        Margin="4,0"
                        Appearance="Secondary"
                        Command="{Binding ClearQueueCommand}" />
                    <Expander
                        x:Name="ColumnsExpander"
                        Width="140"
                        Margin="4,0"
                        HorizontalAlignment="Right"
                        Header="{DynamicResource s_Columns}">
                        <StackPanel>
                            <CheckBox
                                x:Name="ChkQueueId"
                                Margin="2"
                                Checked="ColumnVisibility_Changed"
                                IsChecked="{Binding ColQueueIdVisible, Mode=TwoWay}"
                                Unchecked="ColumnVisibility_Changed" />
                            <CheckBox
                                x:Name="ChkArtist"
                                Margin="2"
                                Checked="ColumnVisibility_Changed"
                                IsChecked="{Binding ColArtistVisible, Mode=TwoWay}"
                                Unchecked="ColumnVisibility_Changed" />
                            <CheckBox
                                x:Name="ChkTitle"
                                Margin="2"
                                Checked="ColumnVisibility_Changed"
                                IsChecked="{Binding ColTitleVisible, Mode=TwoWay}"
                                Unchecked="ColumnVisibility_Changed" />
                            <CheckBox
                                x:Name="ChkLength"
                                Margin="2"
                                Checked="ColumnVisibility_Changed"
                                IsChecked="{Binding ColLengthVisible, Mode=TwoWay}"
                                Unchecked="ColumnVisibility_Changed" />
                            <CheckBox
                                x:Name="ChkRequester"
                                Margin="2"
                                Checked="ColumnVisibility_Changed"
                                IsChecked="{Binding ColRequesterVisible, Mode=TwoWay}"
                                Unchecked="ColumnVisibility_Changed" />
                            <CheckBox
                                x:Name="ChkActions"
                                Margin="2"
                                Checked="ColumnVisibility_Changed"
                                IsChecked="{Binding ColActionsVisible, Mode=TwoWay}"
                                Unchecked="ColumnVisibility_Changed" />
                        </StackPanel>
                    </Expander>
                    <ui:Button
                        Margin="4,0"
                        Appearance="Secondary"
                        Command="{Binding FontSizeDownCommand}"
                        Content="A-"
                        ToolTip="Decrease font size" />
                    <TextBlock
                        MinWidth="24"
                        Margin="4,0"
                        VerticalAlignment="Center"
                        Text="{Binding FontSize}"
                        TextAlignment="Center" />
                    <ui:Button
                        Margin="4,0"
                        Appearance="Secondary"
                        Command="{Binding FontSizeUpCommand}"
                        Content="A+"
                        ToolTip="Increase font size" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="8">
            <TabItem Header="Queue">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DataGrid
                        x:Name="QueueDataGrid"
                        Grid.Row="0"
                        Margin="0,4"
                        AutoGenerateColumns="False"
                        Background="Transparent"
                        BeginningEdit="DataGrid_BeginningEdit"
                        BorderThickness="0"
                        CanUserAddRows="False"
                        CanUserSortColumns="False"
                        FontSize="{Binding FontSize}"
                        GridLinesVisibility="Horizontal"
                        HeadersVisibility="Column"
                        ItemsSource="{Binding QueueTracks}"
                        RowBackground="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        SelectedItem="{Binding SelectedQueueItem, Mode=TwoWay}"
                        SelectionMode="Single"
                        SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                x:Name="ColQueueId"
                                Width="*"
                                Binding="{Binding Queueid}"
                                Header="Queue ID" />
                            <DataGridTextColumn
                                x:Name="ColArtist"
                                Width="*"
                                Binding="{Binding Artist}"
                                Header="{DynamicResource bw_cbArtist}" />
                            <DataGridTextColumn
                                x:Name="ColTitle"
                                Width="*"
                                Binding="{Binding Title}"
                                Header="{DynamicResource crw_RewardTitle}" />
                            <DataGridTextColumn
                                x:Name="ColLength"
                                Width="*"
                                Binding="{Binding Length}"
                                Header="{DynamicResource s_Length}" />
                            <DataGridTextColumn
                                x:Name="ColRequester"
                                Width="*"
                                Binding="{Binding Requester}"
                                Header="{DynamicResource s_Requester}" />
                            <DataGridTemplateColumn
                                x:Name="ColActions"
                                Width="*"
                                Header="{DynamicResource WinQueue_Actions}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <ui:Button
                                                Appearance="Secondary"
                                                Command="{Binding DataContext.SkipCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Content="Skip"
                                                ToolTip="Skip song">
                                                <ui:Button.Style>
                                                    <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="ui:Button">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding PlayerType}" Value="Spotify">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Requester}" Value="Skipping...">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:Button.Style>
                                            </ui:Button>
                                            <ui:Button
                                                Margin="4,0,0,0"
                                                Appearance="Secondary"
                                                Command="{Binding DataContext.AddToFavoritesCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Content="♥"
                                                ToolTip="Add to favorites">
                                                <ui:Button.Style>
                                                    <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="ui:Button">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding PlayerType}" Value="Spotify">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Requester}" Value="Skipping...">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:Button.Style>
                                            </ui:Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Requester}" Value="Skipping...">
                                        <Setter Property="Background" Value="{StaticResource RowSkipping}" />
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Played}" Value="-1">
                                        <Setter Property="Background" Value="{StaticResource RowNowPlaying}" />
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                </Style.Triggers>
                                <Setter Property="Background" Value="{StaticResource RowSongRequest}" />
                                <Setter Property="Foreground" Value="White" />
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Click="ContextMenu_RemoveFromQueue_Click" Header="Remove from queue" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>
                    <Border
                        Grid.Row="1"
                        Margin="0,4"
                        Padding="8,6"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="{Binding PlayerControlsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                            <ui:Button
                                Margin="4,0"
                                Appearance="Secondary"
                                Command="{Binding BackCommand}"
                                Content="⏮"
                                ToolTip="Previous / Restart" />
                            <ui:Button
                                Width="44"
                                Height="44"
                                Margin="4,0"
                                Appearance="Primary"
                                Command="{Binding PlayPauseCommand}"
                                Content="▶"
                                ToolTip="Play / Pause">
                                <ui:Button.Style>
                                    <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="ui:Button">
                                        <Setter Property="Content" Value="❚❚" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPlaying}" Value="False">
                                                <Setter Property="Content" Value="▶" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                            </ui:Button>
                            <ui:Button
                                Margin="4,0"
                                Appearance="Secondary"
                                Command="{Binding NextCommand}"
                                Content="⏭"
                                ToolTip="Next" />
                        </StackPanel>
                    </Border>
                    <ui:Button
                        Grid.Row="1"
                        Margin="0,4"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Appearance="Secondary"
                        Command="{Binding TogglePlayerControlsCommand}"
                        Content="▼"
                        ToolTip="Show / Hide player controls">
                        <ui:Button.Style>
                            <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="ui:Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PlayerControlsVisible}" Value="False">
                                        <Setter Property="Content" Value="▲" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>
                </Grid>
            </TabItem>
            <TabItem Header="Request list">
                <DataGrid
                    x:Name="ReqListDataGrid"
                    Margin="8"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserSortColumns="False"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    ItemsSource="{Binding ReqList}"
                    SelectedItem="{Binding SelectedReqListItem, Mode=TwoWay}"
                    SelectionMode="Single"
                    SelectionUnit="FullRow">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding Trackid}"
                            Header="Track ID" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding Artist}"
                            Header="{DynamicResource bw_cbArtist}" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding Title}"
                            Header="{DynamicResource crw_RewardTitle}" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding Played}"
                            Header="Played" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding Requester}"
                            Header="{DynamicResource s_Requester}" />
                        <DataGridTemplateColumn Width="Auto" Header="{DynamicResource WinQueue_Actions}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ui:Button
                                        Appearance="Secondary"
                                        Command="{Binding DataContext.RemoveFromReqListCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Content="✕"
                                        ToolTip="Remove" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</ui:FluentWindow>