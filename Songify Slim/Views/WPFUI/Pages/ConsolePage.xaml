<Page
    x:Class="Songify_Slim.Views.WPFUI.Pages.ConsolePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Console"
    VerticalAlignment="Stretch"
    ScrollViewer.CanContentScroll="False"
    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
    ScrollViewer.PanningMode="None"
    ScrollViewer.VerticalScrollBarVisibility="Disabled">
    <Grid Margin="24" VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="0" />
        </Grid.RowDefinitions>

        <Grid
            Grid.Row="0"
            Margin="0,0,0,16"
            VerticalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                FontSize="28"
                FontWeight="SemiBold"
                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                Text="Console" />
            <ui:Button
                Grid.Column="1"
                Margin="0,0,12,0"
                Appearance="Secondary"
                Click="BtnClearConsole_Click"
                Content="Clear" />
            <ui:Button
                Grid.Column="2"
                Appearance="Secondary"
                Click="BtnRefreshMetrics_Click"
                Content="Refresh metrics" />
        </Grid>
        <Grid
            Grid.Row="1"
            MinHeight="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
            <Grid
                MinHeight="0"
                VerticalAlignment="Stretch"
                ClipToBounds="True">
                <TabControl
                    MinHeight="0"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch">
                    <TabItem
                        MinWidth="75"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Stretch"
                        Header="Log">
                        <Grid MinHeight="0" VerticalAlignment="Stretch">
                            <RichTextBox
                                x:Name="RtbConsole"
                                MinHeight="0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Background="#252525"
                                BorderThickness="0"
                                FontSize="9"
                                Foreground="White"
                                IsReadOnly="True"
                                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                TextChanged="RtbConsole_TextChanged" />
                        </Grid>
                    </TabItem>
                    <TabItem Header="API metrics">
                        <DataGrid
                            MinHeight="0"
                            Margin="12"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            AutoGenerateColumns="False"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            CanUserReorderColumns="False"
                            CanUserResizeColumns="True"
                            CanUserSortColumns="True"
                            HeadersVisibility="Column"
                            IsReadOnly="True"
                            ItemsSource="{Binding Rows}">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Key}"
                                    Header="Endpoint" />
                                <DataGridTextColumn
                                    Width="140"
                                    Binding="{Binding RequestsPerMinute}"
                                    Header="Requests / min" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="Graph">
                        <Grid
                            MinHeight="0"
                            Margin="12"
                            VerticalAlignment="Stretch">
                            <ContentControl
                                x:Name="ApiChartHost"
                                MinHeight="0"
                                VerticalAlignment="Stretch" />
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
    </Grid>
</Page>