<Page
    x:Class="Songify_Slim.Views.WPFUI.Pages.OverviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Overview"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel
            MaxWidth="800"
            Margin="24"
            VerticalAlignment="Stretch">
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    FontSize="28"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    Text="Overview" />
                <ComboBox
                    x:Name="CbxPlayer"
                    Grid.Column="1"
                    MinWidth="190"
                    VerticalAlignment="Center"
                    SelectionChanged="CbxPlayer_SelectionChanged" />
            </Grid>

            <!--  Now playing: compact card, no stretched empty space  -->
            <ui:Card
                Margin="0,0,0,20"
                Padding="16"
                HorizontalAlignment="Stretch">
                <Grid HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid Margin="0,0,12,0">
                        <ui:Image
                            x:Name="ImgCover"
                            MaxWidth="120"
                            MaxHeight="120"
                            CornerRadius="12"
                            RenderOptions.BitmapScalingMode="HighQuality"
                            Stretch="UniformToFill" />

                        <ui:Card
                            x:Name="CoverPlaceholder"
                            Width="120"
                            Height="120"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                            Visibility="Visible">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                Text="No track" />
                        </ui:Card>
                    </Grid>
                    <StackPanel
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center">
                        <TextBlock
                            x:Name="TxtNowPlaying"
                            FontSize="36"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="Nothing playing"
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="TxtArtist"
                            FontSize="18"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text=""
                            TextWrapping="Wrap" />
                        <StackPanel
                            x:Name="PlayingStatePanel"
                            Margin="0,8,0,0"
                            Orientation="Horizontal">
                            <Border
                                x:Name="PlayingBadge"
                                Padding="6,2"
                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                CornerRadius="4"
                                Visibility="Collapsed">
                                <TextBlock
                                    x:Name="TxtPlayState"
                                    FontSize="11"
                                    Foreground="White"
                                    Text="Playing" />
                            </Border>
                            <TextBlock
                                x:Name="TxtDuration"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                Text="" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ui:Card>
            <!--  Quick actions  -->
            <TextBlock
                Margin="0,0,0,12"
                FontSize="16"
                FontWeight="SemiBold"
                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                Text="Quick actions"
                Visibility="Collapsed" />
            <WrapPanel Margin="0,0,0,0" Visibility="Collapsed">
                <ui:Button
                    x:Name="BtnSettings"
                    Margin="0,0,12,12"
                    Appearance="Secondary"
                    Click="BtnSettings_Click"
                    Content="Settings" />
                <ui:Button
                    x:Name="BtnQueue"
                    Margin="0,0,12,12"
                    Appearance="Secondary"
                    Click="BtnQueue_Click"
                    Content="Queue" />
                <ui:Button
                    x:Name="BtnTwitchConnect"
                    Margin="0,0,12,12"
                    Appearance="Secondary"
                    Click="BtnTwitchConnect_Click"
                    Content="Connect" />
                <ui:Button
                    x:Name="BtnSupport"
                    Margin="0,0,12,12"
                    Appearance="Primary"
                    Click="BtnSupport_Click"
                    Content="Support" />
            </WrapPanel>

            <StackPanel
                Margin="0,0,0,20"
                VerticalAlignment="Bottom"
                Orientation="Horizontal">
                <Ellipse
                    Width="10"
                    Height="10"
                    VerticalAlignment="Center"
                    Fill="{Binding TwitchApiBrush}" />
                <TextBlock
                    Margin="6,0,14,0"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="Twitch API" />

                <Ellipse
                    Width="10"
                    Height="10"
                    VerticalAlignment="Center"
                    Fill="{Binding TwitchBotBrush}" />
                <TextBlock
                    Margin="6,0,14,0"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="Twitch Bot" />

                <Ellipse
                    Width="10"
                    Height="10"
                    VerticalAlignment="Center"
                    Fill="{Binding SpotifyBrush}" />
                <TextBlock
                    Margin="6,0,14,0"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="Spotify" />

                <Ellipse
                    Width="10"
                    Height="10"
                    VerticalAlignment="Center"
                    Fill="{Binding WebServerBrush}" />
                <TextBlock
                    Margin="6,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="WebServer" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>