<Page
    x:Class="Songify_Slim.Views.WPFUI.Pages.QueuePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Queue"
    ScrollViewer.CanContentScroll="False"
    mc:Ignorable="d">
    <Page.Resources>
        <ResourceDictionary>
            <!--  No converters: visibility via DataTriggers, images via ViewModel/Model ImageSource  -->
            <!--  Badge colors (theme-friendly)  -->
            <SolidColorBrush x:Key="BadgeNowPlaying" Color="#4682B4" />
            <SolidColorBrush x:Key="BadgeSongRequest" Color="#2E8B57" />
            <SolidColorBrush x:Key="BadgeSkipping" Color="#CD5C5C" />
            <!--  Queue item card style (in resources so Card has single content child)  -->
            <Style x:Key="QueueItemCardStyle" TargetType="ui:Card">
                <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                        <Setter Property="BorderThickness" Value="2" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Page.Resources>
    <Grid Margin="24" VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" MinHeight="52" />
            <RowDefinition Height="*" MinHeight="80" />
        </Grid.RowDefinitions>
        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,16"
            Orientation="Horizontal">
            <ui:Button
                x:Name="BtnClearQueue"
                Margin="0,0,12,0"
                Appearance="Secondary"
                Command="{Binding ClearQueueCommand}" />
            <ui:Button
                Margin="0,0,12,0"
                Appearance="Secondary"
                Command="{Binding FontSizeDownCommand}"
                Content="A-" />
            <TextBlock
                MinWidth="24"
                Margin="0,0,12,0"
                VerticalAlignment="Center"
                FontSize="{Binding FontSize}"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="{Binding FontSize}" />
            <ui:Button
                Margin="0,0,12,0"
                Appearance="Secondary"
                Command="{Binding FontSizeUpCommand}"
                Content="A+" />
        </StackPanel>
        <!--  Fixed row: currently playing (compact; Border avoids Card Content-set-twice designer issue)  -->
        <Border
            Grid.Row="1"
            Margin="0,0,0,12"
            Padding="10"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="6">
            <Grid>
                <!--  When a track is playing: small cover + title + artist + Now playing pill (from queue or GlobalObjects.CurrentSong)  -->
                <StackPanel Orientation="Horizontal">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasNowPlayingDisplay}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Border
                        Width="40"
                        Height="40"
                        Margin="0,0,12,0"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        ClipToBounds="True"
                        CornerRadius="4">
                        <Grid>
                            <Border Background="{DynamicResource ControlFillColorSecondaryBrush}" CornerRadius="6">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="9"
                                    Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                    Text="No art" />
                            </Border>
                            <ui:Image
                                CornerRadius="6"
                                RenderOptions.BitmapScalingMode="HighQuality"
                                Source="{Binding NowPlayingDisplay.AlbumcoverImageSource}"
                                Stretch="UniformToFill" />
                        </Grid>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="{Binding NowPlayingDisplay.Title}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            Margin="0,1,0,0"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="{Binding NowPlayingDisplay.Artist}"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <Border
                        Margin="12,0,0,0"
                        Padding="6,2"
                        VerticalAlignment="Center"
                        Background="{StaticResource BadgeNowPlaying}"
                        CornerRadius="8">
                        <TextBlock
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="Now playing" />
                    </Border>
                </StackPanel>
                <!--  When nothing is playing  -->
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="13"
                    Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                    Text="Nothing playing">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasNowPlayingDisplay}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>
        <!--  Our ScrollViewer so we control wheel scroll speed; right padding so scrollbar does not overlay actions  -->
        <ScrollViewer
            x:Name="QueueScrollViewer"
            Grid.Row="2"
            Padding="0,0,14,0"
            HorizontalScrollBarVisibility="Disabled"
            PreviewMouseWheel="QueueScrollViewer_PreviewMouseWheel"
            VerticalScrollBarVisibility="Auto">
            <ListBox
                x:Name="QueueListBox"
                Padding="0"
                Background="Transparent"
                BorderThickness="0"
                ItemsSource="{Binding QueueTracks}"
                SelectedItem="{Binding SelectedQueueItem, Mode=TwoWay}"
                VirtualizingPanel.IsVirtualizing="False">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0,0,0,12" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <ui:Card
                            Margin="0,0,0,12"
                            Padding="16"
                            HorizontalAlignment="Stretch"
                            BorderThickness="1"
                            Style="{StaticResource QueueItemCardStyle}">
                            <!--  Horizontal layout: album cover | title/artist/meta (pills on meta row) | actions  -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <!--  Album cover (left)  -->
                                <Border
                                    Grid.Column="0"
                                    Width="56"
                                    Height="56"
                                    Margin="0,0,16,0"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    ClipToBounds="True"
                                    CornerRadius="6">
                                    <Grid>
                                        <Border Background="{DynamicResource ControlFillColorSecondaryBrush}" CornerRadius="12">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="10"
                                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                Text="No art" />
                                        </Border>
                                        <ui:Image
                                            CornerRadius="12"
                                            RenderOptions.BitmapScalingMode="HighQuality"
                                            Source="{Binding AlbumcoverImageSource}"
                                            Stretch="UniformToFill" />
                                    </Grid>
                                </Border>
                                <!--  Title, Artist, Queue#, Length, Requester (fixed position after cover so text never shifts)  -->
                                <StackPanel
                                    Grid.Column="1"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Center"
                                    Orientation="Vertical">
                                    <TextBlock
                                        FontSize="{Binding DataContext.FontSize, RelativeSource={RelativeSource AncestorType=Page}}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                        Text="{Binding Title}"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        FontSize="13"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                        Text="{Binding Artist}"
                                        TextWrapping="Wrap" />
                                    <StackPanel
                                        Margin="0,4,0,0"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                            Text="{Binding Queueid, StringFormat='#{0}'}"
                                            Visibility="Collapsed" />
                                        <TextBlock
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                            Text="{Binding Length}"
                                            Visibility="Collapsed" />
                                        <!--  Now playing pill (same size/style as requester)  -->
                                        <Border
                                            Padding="8,3"
                                            VerticalAlignment="Center"
                                            Background="{StaticResource BadgeNowPlaying}"
                                            CornerRadius="10">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Played}" Value="-1">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Foreground="White"
                                                Text="Now playing" />
                                        </Border>
                                        <!--  Skipping pill (same size/style as requester)  -->
                                        <Border
                                            Padding="8,3"
                                            VerticalAlignment="Center"
                                            Background="{StaticResource BadgeSkipping}"
                                            CornerRadius="10">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Requester}" Value="Skipping...">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon
                                                    Margin="0,0,6,0"
                                                    Filled="True"
                                                    Foreground="White"
                                                    Symbol="SkipForwardTab20" />
                                                <TextBlock
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Foreground="White"
                                                    Text="Skipping" />
                                            </StackPanel>
                                        </Border>
                                        <!--  Requester pill  -->
                                        <Border
                                            Padding="8,3"
                                            VerticalAlignment="Center"
                                            Background="{StaticResource BadgeSongRequest}"
                                            CornerRadius="10">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Requester}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Requester}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Requester}" Value="Skipping...">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Requester}" Value="Spotify">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Requester}" Value="spotify">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Requester}" Value="YouTube">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Requester}" Value="youtube">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon
                                                    Margin="0,0,6,0"
                                                    Filled="True"
                                                    Foreground="White"
                                                    Symbol="Person28" />
                                                <TextBlock
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Foreground="White"
                                                    Text="{Binding Requester, StringFormat='Requested by {0}'}" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                                <!--  Actions (right)  -->
                                <StackPanel
                                    Grid.Column="2"
                                    Margin="0,0,6,0"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <ui:Button
                                        Appearance="Secondary"
                                        Command="{Binding DataContext.SkipCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        Content="Skip" />
                                    <ui:Button
                                        Margin="8,0,0,0"
                                        Appearance="Secondary"
                                        Command="{Binding DataContext.AddToFavoritesCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        Content="♥" />
                                </StackPanel>
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>
    </Grid>
</Page>