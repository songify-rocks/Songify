                            VerticalAlignment="Center"
                            Text="{DynamicResource window_settings_youtube_api_key}" />

                        <PasswordBox
                            x:Name="PasswordBox_YoutubeApiKey"
                            Grid.Row="0"
                            Grid.Column="1"
                            Height="30"
                            Margin="6"
                            Padding="0,0,30,0"
                            VerticalContentAlignment="Center"
                            PasswordChanged="PasswordBox_YoutubeApiKey_OnPasswordChanged" />

                        <Button
                            x:Name="BtnTestYoutubeApi"
                            Grid.Row="2"
                            Grid.Column="0"
                            Margin="0,6"
                            VerticalAlignment="Top"
                            Click="BtnTestYoutubeApi_OnClick"
                            Content="{DynamicResource window_settings_test_api}" />
                        <TextBlock
                            x:Name="TextBlock_YoutubeApiResult"
                            Grid.Row="2"
                            Grid.Column="1"
                            Margin="12,6" />
                    </Grid>
                </Border>
            </TabItem>
            <TabItem
                d:Header="{DynamicResource window_settings_tab_webserver}"
                Header="{DynamicResource window_settings_tab_webserver}"
                Tag="WebServer">
                <Border
                    Margin="10,0,0,0"
                    BorderBrush="{DynamicResource MahApps.Brushes.Accent3}"
                    BorderThickness="2,0,0,0">
                    <Grid Margin="10,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32" />
                            <RowDefinition Height="32" />
                        </Grid.RowDefinitions>
                        <Label
                            Grid.Row="0"
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            d:Content="{DynamicResource window_settings_webserver_port}"
                            Content="{DynamicResource window_settings_webserver_port}" />
                        <controls:NumericUpDown
                            x:Name="NudServerPort"
                            Grid.Row="0"
                            Grid.Column="0"
                            Width="80"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            HideUpDownButtons="True"
                            Maximum="66535"
                            MaximumReached="NudServerPort_MaximumReached"
                            Minimum="1025"
                            MinimumReached="NudServerPort_MinimumReached"
                            ValueChanged="NudServerPort_ValueChanged" />
                        <Button
                            x:Name="BtnWebserverStart"
                            Grid.Row="0"
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            d:Content="{DynamicResource window_settings_webserver_start}"
                            Click="BtnWebserverStart_Click"
                            Content="{DynamicResource window_settings_webserver_start}" />
                        <controls:ToggleSwitch
                            x:Name="TglAutoStartWebserver"
                            Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Height="32"
                            Margin="0,4,0,4"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            d:Content="{DynamicResource window_settings_webserver_auto_start}"
                            Content="{DynamicResource window_settings_webserver_auto_start}"
                            Toggled="TglAutoStartWebserver_Toggled" />
                        <Button
                            x:Name="BtnWebserverOpenUrl"
                            Grid.Row="1"
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            d:Content="{DynamicResource window_settings_webserver_open_website}"
                            Click="BtnWebserverOpenUrl_OnClick"
                            Content="{DynamicResource window_settings_webserver_open_website}" />
                    </Grid>
                </Border>
            </TabItem>
            <TabItem
                d:Header="{DynamicResource window_settings_tab_config}"
                Header="{DynamicResource window_settings_tab_config}"
                Tag="Config">
                <Border
                    Margin="10,0,0,0"
                    BorderBrush="{DynamicResource MahApps.Brushes.Accent3}"
                    BorderThickness="2,0,0,0">
                    <Grid Margin="10,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32" />
                            <RowDefinition Height="32" />
                            <RowDefinition Height="32" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button
                            x:Name="BtnExportConfig"
                            Grid.Row="0"
                            Grid.Column="1"
                            Width="170"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            d:Content="{DynamicResource window_settings_config_export}"
                            Click="Btn_ExportConfig_Click"
                            Content="{DynamicResource window_settings_config_export}" />
                        <Button
                            x:Name="BtnImportConfig"
                            Grid.Row="1"
                            Grid.Column="1"
                            Width="170"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            d:Content="{DynamicResource window_settings_config_import}"
                            Click="Btn_ImportConfig_Click"
                            Content="{DynamicResource window_settings_config_import}"
                            Visibility="Visible" />
                        <Button
                            x:Name="BtnResetConfig"
                            Grid.Row="2"
                            Grid.Column="1"
                            Width="170"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            d:Content="{DynamicResource window_settings_config_reset}"
                            Click="Btn_ResetConfig_Click"
                            Content="{DynamicResource window_settings_config_reset}" />
                        <Label
                            Grid.Row="0"
                            Grid.Column="0"
                            Content="{DynamicResource window_settings_twitch_auth_ports}" />
                        <StackPanel
                            Grid.Row="1"
                            Grid.RowSpan="2"
                            Grid.Column="0"
                            Orientation="Vertical">
                            <StackPanel Orientation="Horizontal">
                                <Label Width="80" Content="{DynamicResource window_settings_redirect_port}" />
                                <ComboBox
                                    x:Name="ComboboxRedirectPort"
                                    MinWidth="100"
                                    SelectionChanged="ComboboxRedirectPort_SelectionChanged" />
                            </StackPanel>
                            <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                                <Label Width="80" Content="{DynamicResource window_settings_fetch_port}" />
                                <ComboBox
                                    x:Name="ComboboxfetchPort"
                                    MinWidth="100"
                                    SelectionChanged="ComboboxfetchPort_SelectionChanged" />
                            </StackPanel>
                        </StackPanel>
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Margin="0,16,0,0"
                            Text="{DynamicResource window_settings_credentials_disclaimer}"
                            TextWrapping="Wrap" />
                        <Button
                            x:Name="BtnSaveCloudSettings"
                            Grid.Row="4"
                            Grid.Column="0"
                            Margin="6"
                            Click="BtnSaveCloudSettings_OnClick">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconForkAwesome
                                        Width="12"
                                        Height="12"
                                        Kind="Upload" />
                                    <TextBlock
                                        Margin="6,0"
                                        VerticalAlignment="Center"
                                        Text="{DynamicResource window_settings_save_cloud}" />
                                </StackPanel>
                            </Button.Content>
                        </Button>
                        <Button
                            x:Name="BtnRestoreCloudSettings"
                            Grid.Row="4"
                            Grid.Column="1"
                            Margin="6"
                            Click="BtnRestoreCloudSettings_OnClick">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconForkAwesome
                                    Width="12"
                                    Height="12"
                                    Kind="Download" />
                                <TextBlock
                                    Margin="6,0"
                                    VerticalAlignment="Center"
                                    Text="Restore Cloud Settings" />
                            </StackPanel>
                        </Button>
                        <TextBlock
                            x:Name="TblError"
                            Grid.Row="5"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Margin="6"
                            Foreground="Red" />
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</controls:MetroWindow>