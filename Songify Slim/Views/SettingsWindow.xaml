<controls:MetroWindow
    x:Class="Songify_Slim.Views.Window_Settings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:general="clr-namespace:Songify_Slim.Util.General"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:Songify_Slim.Properties"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:userControls="clr-namespace:Songify_Slim.UserControls"
    Title="{DynamicResource menu_file_settings}"
    Width="860"
    Height="490"
    MinHeight="400"
    d:Title="{DynamicResource menu_file_settings}"
    Closing="MetroWindow_Closing"
    Loaded="SettingsWindow_Loaded"
    LocationChanged="MetroWindow_LocationChanged"
    ResizeMode="CanResizeWithGrip"
    SizeChanged="MetroWindow_SizeChanged"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <controls:MetroWindow.Resources>
        <general:LastItemVisibilityConverter x:Key="LastItemVisibilityConverter" />
        <Style
            x:Key="TextBoxTextBlock"
            BasedOn="{StaticResource {x:Type TextBox}}"
            TargetType="TextBox">
            <Style.Setters>
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Margin" Value="0,0,0,0" />
                <Setter Property="Padding" Value="0,0,0,0" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="Height" Value="18" />
            </Style.Setters>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Accent4}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </controls:MetroWindow.Resources>
    <controls:MetroWindow.RightWindowCommands>
        <controls:WindowCommands>
            <Button
                x:Name="BtnResponseParams"
                d:Content="{DynamicResource window_settings_response_variables}"
                Click="BtnResponseParams_OnClick"
                Content="{DynamicResource window_settings_response_variables}" />
        </controls:WindowCommands>
    </controls:MetroWindow.RightWindowCommands>
    <Grid>
        <Grid
            x:Name="GridLoading"
            Background="#CC000000"
            Visibility="Collapsed"
            ZIndex="10001">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Vertical">
                <TextBlock
                    x:Name="TbGridLoading"
                    Margin="0,0,0,6"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="White"
                    Text="{DynamicResource window_settings_getting_ready}" />
                <controls:ProgressRing Foreground="{DynamicResource MahApps.Brushes.Accent}" />
            </StackPanel>
        </Grid>
        <TabControl
            x:Name="TabCtrl"
            Margin="10,0,10,0"
            TabStripPlacement="Left">
            <TabItem
                d:Header="{DynamicResource window_settings_tab_system}"
                Header="{DynamicResource window_settings_tab_system}"
                Tag="System">
                <Border
                    Margin="10,0,0,0"
                    BorderBrush="{DynamicResource MahApps.Brushes.Accent3}"
                    BorderThickness="2,0,0,0">
                    <ScrollViewer>
                        <Grid Margin="10,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <Label
                                    Padding="0,6,3,6"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    d:Content="{DynamicResource window_settings_system_language}"
                                    Content="{DynamicResource window_settings_system_language}" />
                                <TextBlock
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    FontSize="9">
                                    <Run>(</Run>
                                    <Hyperlink NavigateUri="https://translate.songify.rocks/" RequestNavigate="Hyperlink_OnRequestNavigate">
                                        Translate!
                                    </Hyperlink>
                                    <Run>)</Run></TextBlock>
                            </StackPanel>
                            <ComboBox
                                x:Name="CbxLanguage"
                                Grid.Row="0"
                                Width="220"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                DisplayMemberPath="Value"
                                SelectedValuePath="Key"
                                SelectionChanged="ComboBox_SelectionChanged"
                                TabIndex="1" />
                            <Label
                                Grid.Row="1"
                                Padding="0,5,5,5"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                d:Content="{DynamicResource window_settings_system_behavior}"
                                Content="{DynamicResource window_settings_system_behavior}" />
                            <StackPanel Grid.Row="2" Orientation="Vertical">
                                <controls:ToggleSwitch
                                    x:Name="ChbxAutostart"
                                    Width="467"
                                    Padding="0"
                                    VerticalAlignment="Top"
                                    d:Content="{DynamicResource window_settings_system_autostart}"
                                    BorderThickness="0"
                                    Content="{DynamicResource window_settings_system_autostart}"
                                    ContentPadding="0"
                                    Focusable="False"
                                    FontFamily="Segoe UI"
                                    FontSize="12"
                                    TabIndex="2"
                                    Toggled="ChbxAutostartChecked" />
                                <controls:ToggleSwitch
                                    x:Name="ChbxMinimizeSystray"
                                    Width="467"
                                    Height="32"
                                    VerticalAlignment="Top"
                                    d:Content="{DynamicResource window_settings_system_minimize}"
                                    Content="{DynamicResource window_settings_system_minimize}"
                                    ContentPadding="0"
                                    Focusable="False"
                                    FontFamily="Segoe UI"
                                    FontSize="12"
                                    TabIndex="3"
                                    Toggled="ChbxMinimizeSystrayChecked" />
                                <controls:ToggleSwitch
                                    x:Name="TglBetaUpdates"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Top"
                                    d:Content="{DynamicResource window_settings_config_beta_updates}"
                                    Content="{DynamicResource window_settings_config_beta_updates}"
                                    FontSize="12"
                                    TabIndex="4"
                                    Toggled="TglBetaUpdates_Toggled" />
                                <controls:ToggleSwitch
                                    x:Name="ChbxOpenQueueOnStartup"
                                    Width="467"
                                    Height="32"
                                    VerticalAlignment="Top"
                                    d:Content="{DynamicResource window_settings_system_open_queue_on_startup}"
                                    Content="{DynamicResource window_settings_system_open_queue_on_startup}"
                                    ContentPadding="0"
                                    Focusable="False"
                                    FontFamily="Segoe UI"
                                    FontSize="12"
                                    TabIndex="5"
                                    Toggled="ChbxOpenQueueOnStartup_Toggled" />
                                <controls:ToggleSwitch
                                    x:Name="TglDonationReminder"
                                    Width="467"
                                    Height="32"
                                    VerticalAlignment="Top"
                                    d:Content="{DynamicResource window_settings_system_disable_donation_reminder}"
                                    Content="{DynamicResource window_settings_system_disable_donation_reminder}"
                                    ContentPadding="0"
                                    Focusable="False"
                                    FontFamily="Segoe UI"
                                    FontSize="12"
                                    TabIndex="6"
                                    Toggled="TglDonationReminder_OnToggled" />
                            </StackPanel>
                            <Label
                                Grid.Row="3"
                                Padding="0,5,5,5"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                d:Content="{DynamicResource window_settings_system_chrome_fetch_rate}"
                                Content="{DynamicResource window_settings_system_chrome_fetch_rate}"
                                Visibility="Collapsed" />
                            <controls:NumericUpDown
                                x:Name="NudChrome"
                                Grid.Row="3"
                                Width="145"
                                Height="28"
                                Padding="0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Interval="1"
                                Maximum="10"
                                Minimum="1"
                                NumericInputMode="Numbers"
                                TabIndex="7"
                                ValueChanged="NudChrome_ValueChanged"
                                Visibility="Collapsed" />
                            <controls:ToggleSwitch
                                x:Name="TglUseDefaultBrowser"
                                Grid.Row="4"
                                VerticalAlignment="Top"
                                d:Content="{DynamicResource window_settings_system_use_default_browser}"
                                Content="{DynamicResource window_settings_system_use_default_browser}"
                                ContentPadding="0"
                                Focusable="False"
                                FontFamily="Segoe UI"
                                FontSize="12"
                                TabIndex="8"
                                Toggled="TglUseDefaultBrowser_OnToggled" />
                            <controls:ToggleSwitch
                                x:Name="TglDebugLogging"
                                Grid.Row="5"
                                Grid.Column="0"
                                Width="467"
                                Height="32"
                                Content="{DynamicResource window_settings_enable_debug_logging}"
                                ContentPadding="0"
                                Focusable="False"
                                FontFamily="Segoe UI"
                                FontSize="12"
                                TabIndex="8"
                                Toggled="TglDebugLogging_OnToggled" />
                            <Label
                                Grid.Row="6"
                                Padding="0,5,5,5"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                d:Content="{DynamicResource window_settings_system_privacy_header}"
                                Content="{DynamicResource window_settings_system_privacy_header}"
                                FontSize="16"
                                Visibility="Collapsed" />
                            <controls:ToggleSwitch
                                x:Name="ToggleSwitchPrivacy"
                                Grid.Row="6"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                d:OffContent="{DynamicResource window_settings_system_privacy}"
                                d:OnContent="{DynamicResource window_settings_system_privacy}"
                                ContentPadding="0"
                                FontFamily="Segoe UI"
                                FontSize="12"
                                OffContent="{DynamicResource window_settings_system_privacy}"
                                OnContent="{DynamicResource window_settings_system_privacy}"
                                Toggled="ToggleSwitchPrivacy_Toggled"
                                Visibility="Collapsed" />
                            <Label
                                Grid.Row="7"
                                Padding="0,5,5,5"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                d:Content="{DynamicResource window_settings_tab_appearance}"
                                Content="{DynamicResource window_settings_tab_appearance}"
                                FontSize="16" />
                            <Label
                                x:Name="LabelColor"
                                Grid.Row="8"
                                Width="71"
                                Padding="5"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                d:Content="{DynamicResource window_settings_appearance_color}"
                                Content="{DynamicResource window_settings_appearance_color}"
                                Visibility="Collapsed" />
                            <ComboBox
                                x:Name="ComboBoxColor"
                                Grid.Row="8"
                                Width="234"
                                Height="23"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                SelectionChanged="ComboBoxColorSelectionChanged"
                                TabIndex="9" />
                            <controls:ToggleSwitch
                                x:Name="ThemeToggleSwitch"
                                Grid.Row="8"
                                Width="145"
                                Height="32"
                                Padding="5,0,0,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                d:OffContent="{DynamicResource window_settings_appearance_theme_light}"
                                d:OnContent="{DynamicResource window_settings_appearance_theme_dark}"
                                ContentPadding="0"
                                FontFamily="Segoe UI"
                                FontSize="12"
                                OffContent="{DynamicResource window_settings_appearance_theme_light}"
                                OnContent="{DynamicResource window_settings_appearance_theme_dark}"
                                TabIndex="10"
                                Toggled="ThemeToggleSwitchIsCheckedChanged" />
                            <Grid Grid.Row="9" Margin="0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Text="{DynamicResource window_settings_songify_api_token}" />
                                <Grid Grid.Column="1" Margin="6,0">
                                    <!--  Password Box  -->
                                    <PasswordBox
                                        x:Name="PasswordBox"
                                        Height="30"
                                        Padding="0,0,30,0"
                                        VerticalContentAlignment="Center"
                                        PasswordChanged="PasswordBox_OnPasswordChanged" />
                                    <!--  Text Box (plain text)  -->
                                    <TextBox
                                        x:Name="TextBox"
                                        Height="30"
                                        Padding="0,0,30,0"
                                        VerticalAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Text="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        TextChanged="TextBox_OnTextChanged"
                                        Visibility="Collapsed" />
                                    <!--  Eye Icon Button  -->
                                    <Button
                                        x:Name="ShowHideButton"
                                        Width="24"
                                        Height="24"
                                        MinWidth="0"
                                        Margin="0,0,3,0"
                                        Padding="0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="0"
                                        Click="ShowHideButton_OnClick"
                                        Style="{DynamicResource MahApps.Styles.Button.Chromeless}">
                                        <iconPacks:PackIconFontAwesome
                                            x:Name="EyeIcon"
                                            Width="20"
                                            Height="20"
                                            Kind="EyeSlashSolid" />
                                    </Button>
                                </Grid>
                                <Button
                                    x:Name="btnApiToken"
                                    Grid.Column="2"
                                    Width="32"
                                    Click="BtnApiToken_OnClick"
                                    Content="{DynamicResource common_help}" />
                            </Grid>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </TabItem>
            <TabItem
                d:Header="{DynamicResource window_settings_tab_output}"
                Header="{DynamicResource window_settings_tab_output}"
                Tag="Output">
                <Border
                    Margin="10,0,0,0"
                    BorderBrush="{DynamicResource MahApps.Brushes.Accent3}"
                    BorderThickness="2,0,0,0">
                    <Grid Margin="10,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="38" />
                            <RowDefinition Height="38" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="38" />
                            <RowDefinition Height="0" />
                            <RowDefinition Height="38" />
                            <RowDefinition Height="38" />
                            <RowDefinition Height="38" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72*" />
                            <ColumnDefinition Width="95*" />
                        </Grid.ColumnDefinitions>
                        <Label
                            Grid.Column="0"
                            Width="99"
                            Height="32"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            d:Content="{DynamicResource window_settings_output_directory}"
                            Content="{DynamicResource window_settings_output_directory}" />
                        <TextBox
                            x:Name="TxtbxOutputdirectory"
                            Grid.Row="0"
                            Grid.Column="1"
                            Height="26"
                            Margin="0,0,64,0"
                            VerticalAlignment="Center"
                            IsReadOnly="True"
                            TextWrapping="NoWrap" />
                        <Button
                            x:Name="BtnOutputdirectory"
                            Grid.Row="0"
                            Grid.Column="1"
                            Width="26"
                            Height="26"
                            Margin="0,0,32,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Click="BtnOutputdirectoryClick"
                            Content="{DynamicResource common_browse}"
                            RenderTransformOrigin="-1.138,0.407" />
                        <Button
                            x:Name="BtnCopyToClip"
                            Grid.Row="0"
                            Grid.Column="1"
                            Width="26"
                            Height="26"
                            Padding="5"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Click="BtnCopyToClipClick"
                            Focusable="False"
                            ToolTip="{DynamicResource window_settings_copy_to_clipboard}">

                            <iconPacks:PackIconFontAwesome
                                Width="15"
                                Height="15"
                                Margin="-1,-1,-1,-1"
                                Kind="LinkSolid" />
                        </Button>
                        <Label
                            Grid.Row="1"
                            Grid.Column="0"
                            Height="32"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            d:Content="{DynamicResource window_settings_output_format}"
                            Content="{DynamicResource window_settings_output_format}" />
                        <TextBox
                            x:Name="TxtbxOutputformat"
                            Grid.Row="1"
                            Grid.Column="1"
                            Height="26"
                            VerticalAlignment="Center"
                            TextChanged="TxtbxOutputformat_TextChanged"
                            TextWrapping="NoWrap">
                            <TextBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem
                                        x:Name="MenuBtnArtist"
                                        Click="MenuBtnArtist_Click"
                                        Header="{DynamicResource common_artist}"
                                        Tag="1" />
                                    <MenuItem
                                        x:Name="MenuBtnTitle"
                                        Click="MenuBtnTitle_Click"
                                        Header="{DynamicResource common_title}"
                                        Tag="1" />
                                    <MenuItem
                                        x:Name="MenuBtnExtra"
                                        Click="MenuBtnExtra_Click"
                                        Header="{DynamicResource window_settings_extra}"
                                        Tag="1" />
                                    <MenuItem
                                        x:Name="MenuBtnReq"
                                        Click="MenuBtnReq_Click"
                                        Header="{DynamicResource common_requester}"
                                        Tag="1" />
                                    <MenuItem
                                        x:Name="MenuBtnUrl"
                                        Click="MenuBtnUrl_Click"
                                        Header="{DynamicResource window_settings_url}"
                                        Tag="1" />
                                    <MenuItem
                                        x:Name="MenuBtnReturn"
                                        Click="MenuBtnReturn_Click"
                                        Header="{DynamicResource window_settings_new_line}"
                                        Tag="1" />
                                </ContextMenu>
                            </TextBox.ContextMenu>
                        </TextBox>
                        <Label
                            Grid.Row="4"
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            d:Content="{DynamicResource window_settings_output_pause}"
                            Content="{DynamicResource window_settings_output_pause}" />
                        <!--<controls:ToggleSwitch
                            x:Name="ChbxCustomPause"
                            Grid.Row="4"
                            Grid.Column="0"
                            Height="32"
                            HorizontalAlignment="Stretch"
                            Content="{DynamicResource window_settings_output_pause_text}"
                            Focusable="False"
                            FontFamily="Segoe UI"
                            FontSize="12"
                            Toggled="ChbxCustompauseChecked" />-->
                        <StackPanel
                            Grid.Row="4"
                            Grid.Column="1"
                            Orientation="Vertical">
                            <ComboBox
                                x:Name="CbPauseOptions"
                                Height="26"
                                Margin="0,0,0,6"
                                SelectionChanged="CbPauseOptions_SelectionChanged">
                                <ComboBoxItem d:Content="{DynamicResource window_settings_output_on_pause_do_nothing}" Content="{DynamicResource window_settings_output_on_pause_do_nothing}" />
                                <ComboBoxItem d:Content="{DynamicResource window_settings_output_on_pause_custom_text}" Content="{DynamicResource window_settings_output_on_pause_custom_text}" />
                                <ComboBoxItem d:Content="{DynamicResource window_settings_output_on_pause_clear_all}" Content="{DynamicResource window_settings_output_on_pause_clear_all}" />
                            </ComboBox>
                            <controls:ToggleSwitch
                                x:Name="tgl_KeepCover"
                                Margin="0,0,0,6"
                                HorizontalAlignment="Right"
                                Content="{DynamicResource window_settings_keep_album_cover}"
                                Toggled="Tgl_KeepCover_OnToggled">
                                <controls:ToggleSwitch.Style>
                                    <Style TargetType="controls:ToggleSwitch">
                                        <Setter Property="IsEnabled" Value="True" />
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedIndex, ElementName=CbPauseOptions}" Value="0">
                                                <Setter Property="IsEnabled" Value="False" />
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </controls:ToggleSwitch.Style>
                            </controls:ToggleSwitch>
                            <TextBox
                                x:Name="TxtbxCustompausetext"
                                Height="26"
                                VerticalAlignment="Center"
                                controls:TextBoxHelper.Watermark="{DynamicResource window_settings_output_pause_watermark}"
                                TextChanged="TxtbxCustompausetext_TextChanged"
                                TextWrapping="Wrap">
                                <TextBox.Style>
                                    <Style BasedOn="{StaticResource {x:Type TextBox}}" TargetType="TextBox">
                                        <Setter Property="IsEnabled" Value="False" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedIndex, ElementName=CbPauseOptions}" Value="1">
                                                <Setter Property="IsEnabled" Value="True" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>

                        <controls:ToggleSwitch
                            x:Name="ChbxUpload"
                            Grid.Row="5"
                            Grid.Column="0"
                            Height="32"
                            HorizontalAlignment="Stretch"
                            d:Content="{DynamicResource window_settings_output_upload_song_info}"
                            Content="{DynamicResource window_settings_output_upload_song_info}"
                            ContentDirection="RightToLeft"
                            ContentPadding="0"
                            Focusable="False"
                            FontFamily="Segoe UI"
                            FontSize="12"
                            Toggled="ChbxUpload_Checked"
                            Visibility="Collapsed" />
                        <controls:ToggleSwitch
                            x:Name="ChbxCover"
                            Grid.Row="8"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Height="32"
                            HorizontalAlignment="Stretch"
                            d:Content="{DynamicResource window_settings_output_download_album}"
                            Content="{DynamicResource window_settings_output_download_album}"
                            ContentPadding="0"
                            Focusable="False"
                            FontFamily="Segoe UI"
                            FontSize="12"
                            Toggled="ChbxCover_Checked" />
                        <controls:ToggleSwitch
                            x:Name="TglCanvas"
                            Grid.Row="9"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Height="32"
                            HorizontalAlignment="Stretch"
                            d:Content="{DynamicResource window_settings_output_download_canvas}"
                            Content="{DynamicResource window_settings_output_download_canvas}"
                            ContentPadding="0"
                            Focusable="False"
                            FontFamily="Segoe UI"
                            FontSize="12"
                            Toggled="TglCanvas_OnToggled" />
                        <StackPanel
                            Grid.Row="5"
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                            <TextBlock
                                Margin="6"
                                VerticalAlignment="Center"
                                Text="{DynamicResource window_settings_copy_song_url}" />
                            <Button
                                x:Name="BtnCopyUrl"
                                Width="26"
                                Height="26"
                                VerticalAlignment="Center"
                                Click="BtnCopyURL_Click">
                                <iconPacks:PackIconFontAwesome
                                    Width="15"
                                    Height="15"
                                    Margin="-1,-2,-1,-2"
                                    Kind="LinkSolid" />
                            </Button>
                        </StackPanel>
                        <controls:ToggleSwitch
                            x:Name="ChbxSplit"
                            Grid.Row="6"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Height="32"
                            HorizontalAlignment="Stretch"
                            d:Content="{DynamicResource window_settings_output_split_artist}"
                            Content="{DynamicResource window_settings_output_split_artist}"
                            ContentPadding="0"
                            Focusable="False"
                            FontFamily="Segoe UI"
                            FontSize="12"
                            Toggled="ChbxSplit_Checked"
                            Visibility="Collapsed" />
                        <Label
                            Grid.Row="7"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            d:Content="{DynamicResource window_settings_output_requester_prefix}"
                            Content="{DynamicResource window_settings_output_requester_prefix}" />
                        <TextBox
                            x:Name="TbRequesterPrefix"
                            Grid.Row="7"
                            Grid.Column="1"
                            Height="26"
                            VerticalAlignment="Center"
                            TextChanged="TbRequesterPrefix_TextChanged" />
                        <Grid Grid.Row="3" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <CheckBox
                                x:Name="ChbxSpaces"
                                Grid.Row="0"
                                Grid.Column="0"
                                Height="18"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                d:Content="{DynamicResource window_settings_output_add_spaces}"
                                Checked="ChbxSpaces_Checked"
                                Content="{DynamicResource window_settings_output_add_spaces}"
                                RenderTransformOrigin="0.47,1.039"
                                Unchecked="ChbxSpaces_Checked" />
                            <controls:NumericUpDown
                                x:Name="NudSpaces"
                                Grid.Row="0"
                                Grid.Column="1"
                                Width="121"
                                Height="26"
                                Margin="0,0,0,0"
                                Padding="0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Interval="1"
                                Minimum="1"
                                NumericInputMode="Numbers"
                                UpDownButtonsWidth="16"
                                ValueChanged="Nud_Spaces_ValueChanged" />
                            <CheckBox
                                x:Name="ChbxSpacesSplitFiles"
                                Grid.Row="1"
                                Grid.Column="0"
